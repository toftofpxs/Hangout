# Serveur
PORT=4000

# Base de donnees MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=eventsdb

# JWT (chaine secrete quelconque, ne pas laisser vide)
JWT_SECRET=change_me_with_a_long_random_string

# SMTP — envoi d'emails (optionnel, le projet fonctionne sans)
# Si SMTP_HOST est vide, les emails sont simplement ignores
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
