PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=eventsdb
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=change_me
SUPER_USER_EMAIL=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081

# Optional SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=

# Cloudinary (optional, recommended in production)
# When configured, uploaded event photos are stored remotely and persist across deploys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_EVENTS_FOLDER=hangout/events
