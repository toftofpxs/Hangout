# =========================
# Global ignore for Hangout monorepo
# =========================

# Secrets / environment files
**/.env
**/.env.*
**/.envrc
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx

# Keep sample env files versioned
!**/.env.example
!**/.env.sample

# Node dependencies
**/node_modules/

# Build / cache outputs
**/dist/
**/build/
**/.cache/
**/.expo/
**/web-build/
**/.parcel-cache/
**/*.tsbuildinfo

# Test / coverage outputs
**/coverage/
**/.nyc_output/

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime / temporary files
**/tmp/
**/temp/

# IDE / OS files
.vscode/
.DS_Store
Thumbs.db


# User-generated uploads (avoid committing private files)
events-backend-js/uploads/
events-backend-js/src/upload/
